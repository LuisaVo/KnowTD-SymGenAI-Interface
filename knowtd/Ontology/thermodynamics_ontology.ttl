        thmo:System ;
    skos:altLabel "closed system" ;
    skos:definition "A closed thermodynamic system contains a macroscopic amount of matter.   There is no mass flow across its boundary, the mass of the system is constant.   Work and heat can be transferred across the system's boundary.  The boundary  can be a real object (e.g. walls) or we can just imagine it.  The system can  move freely in space. Everything outside the system is called \"surroundings\"." ;
    skos:exactMatch wikidata:Q1468684 ;
    skos:inScheme <https://gitlab.rhrk.uni-kl.de/knowtd/knowtd/-/blob/main/Ontology/thermodynamics_ontology.yaml> .

thmo:IsentropicPerfectGasTechnicalWorkEquation a owl:Class ;
    rdfs:label "IsentropicPerfectGasTechnicalWorkEquation" ;
    schema1:mathExpression "w_t = kappa * w_i" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom owl:Thing ;
            owl:onProperty thmo:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty thmo:satisfied ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty thmo:as_text ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty thmo:as_text ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty thmo:satisfied ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty thmo:change_of_state ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty thmo:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty thmo:system ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty thmo:satisfied ],
        [ a owl:Restriction ;
            owl:allValuesFrom thmo:ChangeOfState ;
            owl:onProperty thmo:change_of_state ],
        [ a owl:Restriction ;
            owl:allValuesFrom thmo:System ;
            owl:onProperty thmo:system ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty thmo:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty thmo:as_text ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty thmo:system ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty thmo:change_of_state ],
