thmo:closed a owl:DatatypeProperty ;
    rdfs:label "closed" ;
    rdfs:range xsd:boolean ;
    skos:definition "A closed thermodynamic system contains a macrocopic amount of matter.  There is no mass flow across its boundary, the mass of the system is constant.  Work and heat can be transferred across the system's boundary. The boundary  can be a real object (e.g. walls) or we can just imagine it. The system can  move freely in space. Everything outside the system is called \"surroundings\"." ;
    skos:exactMatch wikidata:Q1468684 ;
    skos:inScheme <https://gitlab.rhrk.uni-kl.de/knowtd/knowtd/-/blob/main/Ontology/thermodynamics_ontology.yaml> .

thmo:motion a owl:DatatypeProperty ;
    rdfs:label "motion" ;
