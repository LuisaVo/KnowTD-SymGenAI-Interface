<https://gitlab.rhrk.uni-kl.de/knowtd/knowtd/-/blob/main/Ontology/thermodynamics_ontology.yaml.owl.ttl> a owl:Ontology ;
    rdfs:label "thermo_ontology" ;
    dcterms:license "https://creativecommons.org/publicdomain/zero/1.0/" ;
    dcterms:title "Thermodynamics Ontology" ;
    pav:version "2.0.0" ;
    skos:definition "Ontology to describe classes relating to thermodynamics. It consists of concepts, variables, attributes, equations, rules and problems" .

thmo:AdditionalEquation a owl:Class ;
    rdfs:label "AdditionalEquation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty thmo:as_text ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty thmo:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom owl:Thing ;
            owl:onProperty thmo:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty thmo:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty thmo:as_text ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty thmo:as_text ],
        thmo:Equation ;
    skos:inScheme <https://gitlab.rhrk.uni-kl.de/knowtd/knowtd/-/blob/main/Ontology/thermodynamics_ontology.yaml> .

thmo:Any a owl:Class ;
    rdfs:label "Any" ;
    rdfs:subClassOf thmo:Element ;
    skos:exactMatch linkml:Any ;
    skos:inScheme <https://gitlab.rhrk.uni-kl.de/knowtd/knowtd/-/blob/main/Ontology/thermodynamics_ontology.yaml> .

