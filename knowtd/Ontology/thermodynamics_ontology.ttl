thmo:SystemProblem a owl:Class ;
    rdfs:label "SystemProblem" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom thmo:System ;
            owl:onProperty thmo:system ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty thmo:invalid_problem ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty thmo:required_variables ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty thmo:problem_class ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty thmo:required_variables ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty thmo:problem_class ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty thmo:valid_problem ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty thmo:valid_problem ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty thmo:system ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty thmo:pureMaterial ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty thmo:pureMaterial ],
        [ a owl:Restriction ;
            owl:allValuesFrom thmo:PureMaterial ;
            owl:onProperty thmo:pureMaterial ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty thmo:additional_equations ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty thmo:system ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty thmo:additional_equations ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty thmo:problem_class ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty thmo:invalid_problem ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty thmo:valid_problem ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty thmo:invalid_problem ],
        thmo:Problem ;
    skos:definition "Basic Problem covering one system with manually entered additional equations and required variables." ;
    skos:exactMatch wikidata:Q503327 ;
    skos:inScheme <https://gitlab.rhrk.uni-kl.de/knowtd/knowtd/-/blob/main/Ontology/thermodynamics_ontology.yaml> .

