thmo:EquationOfStateModels a owl:Class ;
    owl:unionOf ( <https://gitlab.rhrk.uni-kl.de/knowtd/knowtd/-/blob/main/Ontology/thermodynamics_ontology.yaml/EquationOfStateModels#ideal+gas> <https://gitlab.rhrk.uni-kl.de/knowtd/knowtd/-/blob/main/Ontology/thermodynamics_ontology.yaml/EquationOfStateModels#van+der+Waals> <https://gitlab.rhrk.uni-kl.de/knowtd/knowtd/-/blob/main/Ontology/thermodynamics_ontology.yaml/EquationOfStateModels#perfect+gas> ) ;
