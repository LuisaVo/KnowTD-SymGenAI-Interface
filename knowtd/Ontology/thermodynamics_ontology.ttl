    skos:altLabel "change of state" ;
    skos:definition "In a \"change of state\" a system undergoes a change from one equilibirum state  (initial state) to another (final state).  The transistion between these states  may or may not be reversible." ;
    skos:exactMatch wikidata:Q213016 ;
    skos:inScheme <https://gitlab.rhrk.uni-kl.de/knowtd/knowtd/-/blob/main/Ontology/thermodynamics_ontology.yaml> .

xsd:boolean a rdfs:Datatype .

xsd:string a rdfs:Datatype .

thmo:system a owl:ObjectProperty ;
    rdfs:label "system" ;
    rdfs:range thmo:System ;
    skos:inScheme <https://gitlab.rhrk.uni-kl.de/knowtd/knowtd/-/blob/main/Ontology/thermodynamics_ontology.yaml> .

thmo:value a owl:DatatypeProperty ;
    rdfs:label "value" ;
    rdfs:range xsd:float ;
    skos:inScheme <https://gitlab.rhrk.uni-kl.de/knowtd/knowtd/-/blob/main/Ontology/thermodynamics_ontology.yaml> .

thmo:satisfied a owl:DatatypeProperty ;
    rdfs:label "satisfied" ;
    rdfs:range xsd:boolean ;
    skos:definition "Indicates whether a rule is satisfied or not." ;
    skos:inScheme <https://gitlab.rhrk.uni-kl.de/knowtd/knowtd/-/blob/main/Ontology/thermodynamics_ontology.yaml> .

thmo:change_of_state a owl:ObjectProperty ;
    rdfs:label "change_of_state" ;
    rdfs:range thmo:ChangeOfState ;
    skos:inScheme <https://gitlab.rhrk.uni-kl.de/knowtd/knowtd/-/blob/main/Ontology/thermodynamics_ontology.yaml> .

thmo:as_text a owl:DatatypeProperty ;
    rdfs:label "as_text" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://gitlab.rhrk.uni-kl.de/knowtd/knowtd/-/blob/main/Ontology/thermodynamics_ontology.yaml> .

thmo:id a owl:ObjectProperty ;
    rdfs:label "id" ;
    skos:inScheme <https://gitlab.rhrk.uni-kl.de/knowtd/knowtd/-/blob/main/Ontology/thermodynamics_ontology.yaml> .

[] a owl:Restriction ;
    rdfs:subClassOf thmo:CyclicProcess ;
    owl:onProperty thmo:problem_class ;
    owl:someValuesFrom thmo:CyclicProcess .

[] rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty thmo:satisfied ;
            owl:someValuesFrom owl:Thing ] ;
    owl:intersectionOf ( [ a owl:Restriction ;
                owl:onProperty thmo:material.equation_of_state.model ;
                owl:someValuesFrom owl:Thing ] thmo:PerfectGasMaterialRule ) .

[] rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty thmo:satisfied ;
            owl:someValuesFrom owl:Thing ] ;
    owl:intersectionOf ( [ a owl:Restriction ;
                owl:onProperty thmo:system.material.equation_of_state.model ;
                owl:someValuesFrom owl:Thing ] thmo:IdealGasRule ) .

[] a owl:Restriction ;
    rdfs:subClassOf thmo:SingleStep ;
    owl:onProperty thmo:problem_class ;
    owl:someValuesFrom thmo:SingleStep .

[] rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty thmo:satisfied ;
            owl:someValuesFrom owl:Thing ] ;
    owl:intersectionOf ( [ a owl:Restriction ;
                owl:onProperty thmo:change_of_state.reversible ;
                owl:someValuesFrom owl:Thing ] thmo:IrreversibleRule ) .

[] rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty thmo:satisfied ;
            owl:someValuesFrom owl:Thing ] ;
    owl:intersectionOf ( [ a owl:Restriction ;
                owl:onProperty thmo:change_of_state.transition.is_isothermal ;
                owl:someValuesFrom owl:Thing ] thmo:IsothermalRule ) .

[] rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty thmo:satisfied ;
            owl:someValuesFrom owl:Thing ] ;
    owl:intersectionOf ( [ a owl:Restriction ;
                owl:onProperty thmo:change_of_state.transition.is_isochoric ;
                owl:someValuesFrom owl:Thing ] thmo:IsochoricRule ) .

[] a owl:Restriction ;
    rdfs:subClassOf thmo:SystemProblem ;
    owl:onProperty thmo:problem_class ;
    owl:someValuesFrom thmo:SystemProblem .

[] rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty thmo:satisfied ;
            owl:someValuesFrom owl:Thing ] ;
    owl:intersectionOf ( [ a owl:Restriction ;
                owl:onProperty thmo:system.material.equation_of_state.model ;
                owl:someValuesFrom owl:Thing ] thmo:PerfectGasRule ) .

[] rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty thmo:satisfied ;
            owl:someValuesFrom owl:Thing ] ;
    owl:intersectionOf ( [ a owl:Restriction ;
                owl:onProperty thmo:change_of_state.transition.motion ;
                owl:someValuesFrom owl:Thing ] thmo:NotInMotionRule ) .

[] rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty thmo:satisfied ;
            owl:someValuesFrom owl:Thing ] ;
    owl:intersectionOf ( [ a owl:Restriction ;
                owl:onProperty thmo:change_of_state.transition.is_polytropic ;
                owl:someValuesFrom owl:Thing ] thmo:PolytropicRule ) .

[] rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty thmo:satisfied ;
            owl:someValuesFrom owl:Thing ] ;
    owl:intersectionOf ( [ a owl:Restriction ;
                owl:onProperty thmo:material.equation_of_state.model ;
                owl:someValuesFrom owl:Thing ] thmo:IdealGasMaterialRule ) .

[] rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty thmo:satisfied ;
            owl:someValuesFrom owl:Thing ] ;
    owl:intersectionOf ( [ owl:intersectionOf ( [ a owl:Restriction ;
                            owl:onProperty thmo:system.closed ;
                            owl:someValuesFrom owl:Thing ] [ a owl:Restriction ;
                            owl:onProperty thmo:system.equilibrium ;
                            owl:someValuesFrom owl:Thing ] [ a owl:Restriction ;
                            owl:onProperty thmo:system.homogeneous ;
                            owl:someValuesFrom owl:Thing ] ) ] thmo:SystemRules ) .

[] a owl:Restriction ;
    rdfs:subClassOf thmo:Equilibrium ;
    owl:onProperty thmo:problem_class ;
    owl:someValuesFrom thmo:Equilibrium .

[] a owl:Restriction ;
    rdfs:subClassOf thmo:Problem ;
    owl:onProperty thmo:problem_class ;
    owl:someValuesFrom thmo:Problem .

[] a owl:Restriction ;
    rdfs:subClassOf thmo:SequentialSteps ;
    owl:onProperty thmo:problem_class ;
    owl:someValuesFrom thmo:SequentialSteps .

[] rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty thmo:satisfied ;
            owl:someValuesFrom owl:Thing ] ;
    owl:intersectionOf ( [ a owl:Restriction ;
                owl:onProperty thmo:change_of_state.transition.adiabatic ;
                owl:someValuesFrom owl:Thing ] thmo:AdiabaticRule ) .

[] rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty thmo:satisfied ;
            owl:someValuesFrom owl:Thing ] ;
    owl:intersectionOf ( [ a owl:Restriction ;
                owl:onProperty thmo:change_of_state.transition.is_isobaric ;
                owl:someValuesFrom owl:Thing ] thmo:IsobaricRule ) .

[] a owl:Restriction ;
    rdfs:subClassOf thmo:SystemSpecification ;
    owl:onProperty thmo:problem_class ;
    owl:someValuesFrom thmo:SystemSpecification .

[] rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty thmo:satisfied ;
            owl:someValuesFrom owl:Thing ] ;
    owl:intersectionOf ( [ a owl:Restriction ;
                owl:onProperty thmo:change_of_state.transition.is_isentropic ;
                owl:someValuesFrom owl:Thing ] thmo:IsentropicRule ) .


