thmo:AmountOfSubstance a owl:Class ;
    rdfs:label "AmountOfSubstance" ;
    schema1:Unit "mol" ;
    schema1:mathExpression "n" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty thmo:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty thmo:value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty thmo:value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty thmo:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:float ;
            owl:onProperty thmo:value ],
        [ a owl:Restriction ;
            owl:allValuesFrom owl:Thing ;
            owl:onProperty thmo:id ],
        thmo:InternalStateVariable,
        thmo:Variable ;
